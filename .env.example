# Neon Postgres — required for yard_properties, proposals, interactions
DATABASE_URL=postgres://...

# Neon Auth — required for session management
NEON_AUTH_BASE_URL=https://...
NEON_AUTH_COOKIE_SECRET=                   # must be at least 32 chars

# Anthropic — required for proposal generation
ANTHROPIC_API_KEY=sk-ant-...

# Gmail — optional, for feedback/bug report emails
GMAIL_USER=
GMAIL_APP_PASSWORD=
FEEDBACK_TO=                               # defaults to GMAIL_USER if not set

# Resend — optional, for newsletter signups (contacts API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_SEGMENT_ID=

# Stripe — optional, not wired yet (subscription billing planned)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=

# Optional: used for canonical URL fallback in some contexts
NEXT_PUBLIC_SITE_URL=https://lawnagent.app